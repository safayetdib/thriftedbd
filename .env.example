# MongoDB Atlas connection string (free M0 tier is fine — it's still a replica set, so transactions work)
MONGODB_URI=

# NextAuth — generate with: npx auth secret
AUTH_SECRET=

# Cloudflare R2 (S3-compatible object storage for product images)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Google Cloud Translation API — used to auto-fill the Bangla draft on product save (docs/i18n-guidelines.md)
GOOGLE_TRANSLATE_API_KEY=
