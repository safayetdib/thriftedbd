{
  "info": {
    "name": "thriftedBD API",
    "description": "Local API collection for thriftedBD. Run requests top-to-bottom within a folder — later requests depend on IDs captured by earlier ones into environment variables. Use the 'thriftedBD Local' environment alongside this collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get CSRF Token",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/auth/csrf"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.environment.set(\"csrfToken\", json.csrfToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "url": "{{baseUrl}}/api/auth/callback/admin",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "csrfToken",
                  "value": "{{csrfToken}}",
                  "type": "text"
                },
                {
                  "key": "email",
                  "value": "{{adminEmail}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{adminPassword}}",
                  "type": "text"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Customer Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "url": "{{baseUrl}}/api/auth/callback/customer",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "csrfToken",
                  "value": "{{csrfToken}}",
                  "type": "text"
                },
                {
                  "key": "email",
                  "value": "{{customerEmail}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{customerPassword}}",
                  "type": "text"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Session",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/auth/session"
          },
          "response": []
        }
      ]
    },
